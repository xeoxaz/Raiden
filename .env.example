# Raiden Configuration
# All settings can also be passed as CLI flags (which take precedence).

# Mode: "host" or "guest"
WS_MODE=guest

# Host options
WS_HOST=0.0.0.0
WS_PORT=8080

# Guest options
WS_URL=ws://localhost:8080/ws
WS_PING_INTERVAL_MS=5000
WS_RECONNECT_INTERVAL_MS=3000
WS_MAX_RECONNECT_ATTEMPTS=10
WS_SAMPLE_LIMIT=100
WS_SPEED_TEST_PAYLOADS=64,1024,16384
WS_SPEED_TEST_INTERVAL_MS=30000
WS_CSV_OUTPUT=

# Logging
WS_LOG_LEVEL=info
